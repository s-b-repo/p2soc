# =============================================================================
# SOC display environment  — copy to .env (dev) or /etc/soc-display/soc.env (Pi)
# NON-SECRET. The vault master password is NOT here: it is sealed host-bound
# under $SOC_SECRET_DIR and fed to rbw by pinentry-vault.py. Run
# `python3 setup.py first-run` to generate the one-time PIN and seal it.
# The wall config lives in Vaultwarden (SOC_CONFIG_VAULT_ITEM). NEVER commit .env.
# =============================================================================

# --- Vaultwarden / rbw -------------------------------------------------------
# rbw talks to your Vaultwarden server. These configure the rbw profile the
# kiosk host unlocks at startup (also baked into rbw's own config by first-run).
SOC_VAULT_EMAIL="kiosk@soc.local"
SOC_VAULT_URL="http://127.0.0.1:8222"
# Where the host-bound sealed master password lives (master.enc / pin.enc, 0600).
SOC_SECRET_DIR="/etc/soc-display/secret"
# Vaultwarden secure-note holding the wall config (the source of truth at boot).
SOC_CONFIG_VAULT_ITEM="SOC Wall Config"
# Set SOC_CONFIG_FROM_VAULT=0 to force the local panels.yaml instead of the note.

# --- Vaultwarden server (only needed on the host running vaultwarden) --------
# Admin token for the /admin page. Generate with: vaultwarden hash  (argon2).
VAULTWARDEN_ADMIN_TOKEN=""
# Bind address. Keep on localhost unless you must manage it from the LAN.
ROCKET_ADDRESS="127.0.0.1"
ROCKET_PORT="8222"
# Disable open registration once your kiosk account exists.
SIGNUPS_ALLOWED="false"

# --- Display / kiosk host ----------------------------------------------------
SOC_PANELS_FILE="/etc/soc-display/panels.yaml"
SOC_DISPLAY=":0"
# Session backend: auto (default) | wayland | xwayland | xlibre | xorg | x11.
SOC_SESSION="auto"
# Stagger window creation (seconds) so 1 GB doesn't spike on boot.
SOC_LAUNCH_STAGGER="1.5"
# Base TCP port for Chromium CDP (each chromium panel gets base+index).
SOC_CDP_BASE_PORT="9222"
# Performance profile is auto-detected; override if needed:
#   SOC_LOW_MEMORY=1            force the lighter WebKit cache (auto <= ~1.5 GB RAM)
#   SOC_WEBKIT_HWACCEL=auto     auto | always | never | ondemand (GPU compositing)
#   SOC_WEBKIT_MEM_LIMIT_MB=256 per web/network-process memory cap (4.1, low-mem)

# --- Readiness gating --------------------------------------------------------
# How long (seconds) the host waits for vault + VPN + tunnels before giving up.
SOC_READY_TIMEOUT="120"

# --- Fortinet VPN (forti-vpn.service) ----------------------------------------
# openfortivpn logs in with the FortiGate login stored in the vault
# (panels.yaml / config note -> vpn.vault_item); it reuses SOC_VAULT_* above and
# the same host-bound sealed secret, so no extra secret lives here. The FortiGate
# password is fed via a pinentry helper — never on argv, never on disk. Set =1 to
# print the command without connecting (cred-resolution smoke; see `make vpn-check`).
SOC_VPN_DRY_RUN="0"
