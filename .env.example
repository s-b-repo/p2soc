# =============================================================================
# SOC display environment  — copy to .env (dev) or /etc/soc-display/soc.env (Pi)
# On the Pi this file MUST live on tmpfs (install.sh mounts /etc/soc-display as
# tmpfs) and be chmod 0600. NEVER commit a real .env.
# =============================================================================

# --- Vaultwarden / rbw -------------------------------------------------------
# rbw talks to your Vaultwarden server. These configure the rbw profile that
# the kiosk host unlocks at startup.
SOC_VAULT_EMAIL="kiosk@soc.local"
SOC_VAULT_URL="http://127.0.0.1:8222"
# The master password used to unlock the vault unattended at boot. This is the
# unattended-kiosk tradeoff: a powered-on Pi can self-unlock. Keep on tmpfs,
# 0600. For higher security, leave blank and unlock manually after each reboot
# (set SOC_VAULT_INTERACTIVE=1).
SOC_VAULT_PASSWORD="change-me"
SOC_VAULT_INTERACTIVE=0

# --- Vaultwarden server (only needed on the host running vaultwarden) --------
# Admin token for the /admin page. Generate with: vaultwarden hash  (argon2).
VAULTWARDEN_ADMIN_TOKEN=""
# Bind address. Keep on localhost unless you must manage it from the LAN.
ROCKET_ADDRESS="127.0.0.1"
ROCKET_PORT="8222"
# Disable open registration once your kiosk account exists.
SIGNUPS_ALLOWED="false"

# --- Display / kiosk host ----------------------------------------------------
SOC_PANELS_FILE="/etc/soc-display/panels.yaml"
SOC_DISPLAY=":0"
# Stagger window creation (seconds) so 1 GB doesn't spike on boot.
SOC_LAUNCH_STAGGER="1.5"
# Base TCP port for Chromium CDP (each chromium panel gets base+index).
SOC_CDP_BASE_PORT="9222"

# --- Readiness gating --------------------------------------------------------
# How long (seconds) the host waits for vault + tunnels before giving up.
SOC_READY_TIMEOUT="120"
