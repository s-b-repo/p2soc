# Kiosk host environment — installed to /etc/soc-display/soc.env (0600).
# Sourced by the launcher and the autossh service. Holds the vault master
# password for unattended unlock: a powered-on kiosk can self-unlock the vault.
# For higher security set SOC_VAULT_INTERACTIVE=1 and unlock manually after boot.

SOC_VAULT_BACKEND=rbw
SOC_VAULT_EMAIL=kiosk@soc.local
SOC_VAULT_URL=http://127.0.0.1:8222
SOC_VAULT_PASSWORD=CHANGE-ME
SOC_VAULT_INTERACTIVE=0
SOC_PINENTRY=/opt/soc-display/scripts/pinentry-soc.sh

SOC_ROOT=/opt/soc-display
SOC_PANELS_FILE=/etc/soc-display/panels.yaml
SOC_INJECT_TMPL=/opt/soc-display/inject/login.js.tmpl

SOC_LAUNCH_STAGGER=1.5
SOC_READY_TIMEOUT=120
SOC_CDP_BASE_PORT=9222
SOC_CRED_TTL=30
