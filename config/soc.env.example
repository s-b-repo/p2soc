# Kiosk host environment — installed to /etc/soc-display/soc.env (0640).
# Sourced by the launcher and the autossh service.
#
# NON-SECRET. The vault master password is NOT here any more: it is sealed,
# host-bound, under $SOC_SECRET_DIR and fed to rbw by pinentry-vault.py — run
# `python3 setup.py first-run` (or `deploy`) to generate the one-time PIN and
# seal it. The wall config (panels/tunnel/vpn/proxy) lives in Vaultwarden as the
# SOC_CONFIG_VAULT_ITEM secure-note; the local panels.yaml is only a fallback.
# See docs/SECURITY.md.

SOC_VAULT_BACKEND=rbw
SOC_VAULT_EMAIL=kiosk@soc.local
SOC_VAULT_URL=http://127.0.0.1:8222
# Host-bound sealed master password lives here (master.enc / pin.enc, 0600).
SOC_SECRET_DIR=/etc/soc-display/secret
# Vaultwarden secure-note that holds the wall config (the source of truth).
SOC_CONFIG_VAULT_ITEM=SOC Wall Config
# Set SOC_CONFIG_FROM_VAULT=0 to force the local panels.yaml instead of the note.

SOC_ROOT=/opt/soc-display
SOC_PANELS_FILE=/etc/soc-display/panels.yaml
SOC_INJECT_TMPL=/opt/soc-display/inject/login.js.tmpl

SOC_LAUNCH_STAGGER=1.5
SOC_READY_TIMEOUT=120
SOC_CDP_BASE_PORT=9222
SOC_CRED_TTL=30

# Display stack (launch option). See docs/INSTALL.md.
#   auto      (default) try Wayland -> XWayland -> XLibre -> Xorg
#   wayland   native Wayland (cage/labwc)        xwayland  Wayland + XWayland
#   xlibre    X11 with the XLibre server         xorg      X11 with X.Org
#   x11       X11 with whatever X server exists
SOC_SESSION=auto
# Wayland only: force a specific compositor (default: auto-pick cage/labwc).
# SOC_COMPOSITOR=sway
# Force a specific X server binary/command (overrides xlibre/xorg detection).
# SOC_XSERVER=/usr/bin/Xorg

# --- Performance profile (auto-detected; uncomment to override) ---------------
# Low-memory profile (lighter WebKit cache). Auto-on when MemTotal <= ~1.5 GB.
# SOC_LOW_MEMORY=1
# WebKit GPU acceleration: auto | always | never | ondemand. Auto = on for ARM
# boards with a GPU render node (Pi 5), on-demand under the low-memory profile.
# SOC_WEBKIT_HWACCEL=auto

# --- Fortinet VPN (forti-vpn.service) ----------------------------------------
# The VPN reuses the SOC_VAULT_* settings above: forti-vpn.service reads the
# FortiGate login from the vault (vpn.vault_item) and unlocks rbw via the same
# host-bound sealed secret + pinentry-vault.py — no extra secret here. Set
# SOC_VPN_DRY_RUN=1 to resolve creds and print the openfortivpn command without
# connecting (used by `make vpn-check`).
SOC_VPN_DRY_RUN=0
