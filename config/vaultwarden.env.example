# Vaultwarden server env — copy to /etc/soc-display/vaultwarden.env (0600).
# Keep the vault bound to localhost; the kiosk host reaches it via rbw on 8222.
DATA_FOLDER=/var/lib/vaultwarden
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8222
# Disable open registration AFTER you have created the kiosk account.
SIGNUPS_ALLOWED=false
# Admin page token (argon2 hash). Generate with: vaultwarden hash
# Then set:  ADMIN_TOKEN='$argon2id$v=19$m=...'
ADMIN_TOKEN=
# Don't require SMTP email verification for the single local account.
SIGNUPS_VERIFY=false
WEBSOCKET_ENABLED=false
