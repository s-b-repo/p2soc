#!/usr/bin/env bash
# inode-ipcfg-helper — privileged helper that applies (or clears) a static IP
# configuration on a network interface. Used for profiles whose IP mode is
# "Static": after an 802.1X/WLAN link authenticates, the supplicant brings no
# address of its own, so the GUI programs one here. Invoked via pkexec because
# changing addresses/routes/DNS needs CAP_NET_ADMIN.
#
# Subcommands:
#   apply --iface IF --ip A.B.C.D --prefix N [--gw G] [--dns "d1,d2"]
#       Add A/N to IF, bring IF up, optionally set a default route via G, and
#       optionally write DNS servers to /etc/resolv.conf (original backed up).
#   clear --iface IF --ip A.B.C.D --prefix N [--gw G]
#       Undo the above: drop the default route we added, remove the address,
#       and restore the original /etc/resolv.conf if we replaced it.
#
# Returns 0 on success, non-zero on failure. Stores no credentials.

set -euo pipefail

die() { echo "helper: $*" >&2; exit 1; }

[[ ${EUID:-$(id -u)} -eq 0 ]] || die "must be run as root (invoke via pkexec)"

cmd=${1:-}; shift || die "usage: $0 apply|clear ..."

IFACE=""
IP=""
PREFIX=""
GW=""
DNS=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --iface)  IFACE=$2;  shift 2 ;;
        --ip)     IP=$2;     shift 2 ;;
        --prefix) PREFIX=$2; shift 2 ;;
        --gw)     GW=$2;     shift 2 ;;
        --dns)    DNS=$2;    shift 2 ;;
        *)        die "unknown arg: $1" ;;
    esac
done

[[ -n $IFACE ]] || die "--iface required"
# Constrain to plausible interface names so nothing can smuggle shell/ip args.
[[ $IFACE =~ ^[A-Za-z0-9._@:-]+$ ]] || die "invalid --iface"
[[ -n $IP ]]     || die "--ip required"
[[ $IP =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]] || die "invalid --ip"
[[ -n $PREFIX ]] || die "--prefix required"
[[ $PREFIX =~ ^[0-9]{1,2}$ ]] && (( PREFIX <= 32 )) || die "invalid --prefix"
[[ -z $GW || $GW =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]] || die "invalid --gw"

RESOLV=/etc/resolv.conf
RESOLV_BAK=${RESOLV}.inode-ipcfg.bak
MARKER="#Line Generated by iNode Client (Qt) static IP"

case "$cmd" in
    apply)
        ip addr replace "${IP}/${PREFIX}" dev "$IFACE"
        ip link set dev "$IFACE" up
        if [[ -n $GW ]]; then
            ip route replace default via "$GW" dev "$IFACE"
        fi
        if [[ -n $DNS ]]; then
            # Back up the real resolv.conf once (don't capture our own file).
            if ! grep -qsF "$MARKER" "$RESOLV"; then
                cp -f "$RESOLV" "$RESOLV_BAK" 2>/dev/null || : > "$RESOLV_BAK"
            fi
            {
                echo "$MARKER"
                # accept comma- or space-separated servers
                for s in ${DNS//,/ }; do
                    [[ $s =~ ^[0-9A-Fa-f:.]+$ ]] && echo "nameserver $s"
                done
            } > "${RESOLV}.inode-tmp"
            mv -f "${RESOLV}.inode-tmp" "$RESOLV"
        fi
        echo "static IP ${IP}/${PREFIX} applied on ${IFACE}"
        ;;

    clear)
        if [[ -n $GW ]]; then
            ip route del default via "$GW" dev "$IFACE" 2>/dev/null || true
        fi
        ip addr del "${IP}/${PREFIX}" dev "$IFACE" 2>/dev/null || true
        if grep -qsF "$MARKER" "$RESOLV" && [[ -f $RESOLV_BAK ]]; then
            mv -f "$RESOLV_BAK" "$RESOLV" 2>/dev/null || true
        fi
        echo "static IP ${IP}/${PREFIX} cleared on ${IFACE}"
        ;;

    *)
        die "unknown subcommand: $cmd"
        ;;
esac
