#!/usr/bin/env bash
# SOC wall launcher menu — soc-wall.desktop runs this when the app icon is
# clicked. It shows a small chooser (Setup / Desktop mode / Kiosk mode) and then
# dispatches to scripts/soc-wall-desktop.sh (--window | --fullscreen) or the
# setup wizard. It attaches to the current desktop session; it never takes over
# tty1. Pure launcher: real work is host/launchermenu.py.
set -euo pipefail

# Self-locating: ROOT = the parent of this scripts/ dir, so the launcher works
# from a dev checkout OR the deployed /opt/soc-display. SOC_ROOT overrides.
SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "$0")"
ROOT="${SOC_ROOT:-$(CDPATH= cd -- "$(dirname -- "$SELF")/.." 2>/dev/null && pwd)}"
[ -d "$ROOT/kiosk-host" ] || ROOT="/opt/soc-display"

export SOC_ROOT="$ROOT"
export PYTHONPATH="$ROOT/kiosk-host${PYTHONPATH:+:$PYTHONPATH}"

# Cap GLib/GTK per-thread malloc arenas (default 8*ncpu) — the single biggest RSS
# cut on the 1GB Pi (same rationale as launcher.sh).
export MALLOC_ARENA_MAX="${MALLOC_ARENA_MAX:-2}"

PYBIN="$ROOT/.venv/bin/python"
[ -x "$PYBIN" ] || PYBIN="$(command -v python3)"

# Resolve SOC_ENV_FILE via the SHARED resolver (host.configpaths) BEFORE sourcing,
# so the menu-spawned wall inherits the SAME soc.env the wall would read. Literal
# fallback (== read tier #3) preserves the non-systemd/pre-install path.
: "${SOC_ENV_FILE:=$("$PYBIN" -m host.configpaths --env 2>/dev/null || true)}"
: "${SOC_ENV_FILE:=/etc/soc-display/soc.env}"
ENV_FILE="$SOC_ENV_FILE"

# Load the (non-secret) env if present so the launched wall sees the same config.
if [ -r "$ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
elif [ -e "$ENV_FILE" ]; then
  echo "WARNING: $ENV_FILE exists but is not readable by $(id -un 2>/dev/null) —" >&2
  echo "  the wall's vault config will not load. Fix: sudo chmod 0644 $ENV_FILE" >&2
fi

# Resolve SOC_PANELS_FILE AFTER sourcing (explicit one in soc.env wins) and export
# both, so the menu-spawned wall inherits the resolved file.
: "${SOC_PANELS_FILE:=$("$PYBIN" -m host.configpaths --panels 2>/dev/null || true)}"
: "${SOC_PANELS_FILE:=/etc/soc-display/panels.yaml}"
export SOC_ENV_FILE SOC_PANELS_FILE

exec "$PYBIN" -m host.launchermenu "$@"
