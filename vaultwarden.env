# Vaultwarden server env — generated by setup.py. Mode 0600.
# Keep the vault bound to localhost; the kiosk reaches it via rbw on 8222.
DATA_FOLDER=/var/lib/vaultwarden
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8222
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=false
WEBSOCKET_ENABLED=false
# Admin page token (argon2). Generate with: vaultwarden hash
ADMIN_TOKEN=
