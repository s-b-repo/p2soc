# SOC kiosk environment — generated by setup.py. Keep on tmpfs, mode 0640.
# Holds the vault master password for unattended unlock (see docs/SECURITY.md).

# --- vault (rbw -> Vaultwarden) ---
SOC_VAULT_BACKEND=dev
SOC_VAULT_EMAIL=kiosk@soc.local
SOC_VAULT_URL=http://127.0.0.1:8222
SOC_VAULT_PASSWORD=
SOC_VAULT_INTERACTIVE=0
SOC_PINENTRY=/home/kali/Projects/soc-wall-deploy/scripts/pinentry-soc.sh

# --- paths ---
SOC_ROOT=/home/kali/Projects/soc-wall-deploy
SOC_PANELS_FILE=/home/kali/Projects/soc-wall-deploy/config/panels.local.yaml
SOC_INJECT_TMPL=/home/kali/Projects/soc-wall-deploy/inject/login.js.tmpl

# --- host tuning ---
SOC_LAUNCH_STAGGER=1.5
SOC_READY_TIMEOUT=120
SOC_CDP_BASE_PORT=9222
SOC_CRED_TTL=30
SOC_VPN_DRY_RUN=0

# --- session backend: x11 | wayland | auto ---
SOC_SESSION=x11
